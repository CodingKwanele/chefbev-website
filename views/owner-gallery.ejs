<section class="section">
  <div class="container owner-shell">
    <div class="section__head owner-head">
      <div>
        <h1 class="section__title">Gallery reference</h1>
        <p class="section__sub">Gallery photos are now managed in the codebase and deployed with the website.</p>
      </div>

      <form method="post" action="/owner/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="btn btn--ghost" type="submit">Log out</button>
      </form>
    </div>

    <% if (success) { %>
      <div class="alert alert--success"><%= success %></div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert--error"><%= error %></div>
    <% } %>

    <div class="alert alert--info">
      To update the gallery, add optimized JPG, PNG, or WebP images to public/img/gallery, update utils/galleryStore.js, then deploy. Bev can still post the same images on social media.
    </div>

    <div class="form__actions">
      <a class="btn btn--primary" href="/gallery">View public gallery</a>
    </div>

    <div class="owner-list">
      <% if (items && items.length > 0) { %>
        <% items.forEach((it) => { %>
          <article class="owner-item">
            <img class="owner-item__img" src="<%= it.src %>" alt="<%= it.title %> cake" loading="lazy" />
            <div class="owner-item__body">
              <h2><%= it.title %></h2>
              <p><%= it.tag %> · <%= it.category %></p>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <div class="empty">
          <div class="empty__title">No photos yet</div>
          <div class="empty__sub">Add images to public/img/gallery and update utils/galleryStore.js.</div>
        </div>
      <% } %>
    </div>
  </div>
</section>
