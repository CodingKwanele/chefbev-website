<section class="section gallery-page">
  <div class="container">
    <div class="gallery-hero">
      <div>
        <p class="owner-kicker">Cake inspiration</p>
        <h1 class="section__title">Choose a look you love</h1>
        <p class="section__sub">
          Browse Chef Bev's recent designs, open any cake for a closer look, then start an order with that style already selected.
        </p>
      </div>

      <% if (items && items.length > 0) { %>
        <div class="gallery-hero__preview" aria-hidden="true">
          <% items.slice(0, 3).forEach((it, index) => { %>
            <img class="gallery-hero__img gallery-hero__img--<%= index + 1 %>" src="<%= it.src %>" alt="" loading="lazy" />
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="gallerybar" role="region" aria-label="Gallery filters">
      <div class="tabs" role="tablist" aria-label="Cake categories">
        <% categories.forEach((c) => { %>
          <% const categoryCount = c.key === 'all' ? items.length : items.filter((it) => it.category === c.key).length; %>
          <button
            class="tab <%= defaultCategory === c.key ? 'is-active' : '' %>"
            type="button"
            role="tab"
            aria-selected="<%= defaultCategory === c.key ? 'true' : 'false' %>"
            data-cat="<%= c.key %>"
          >
            <span><%= c.label %></span>
            <strong><%= categoryCount %></strong>
          </button>
        <% }) %>
      </div>

      <div class="search">
        <input
          class="search__input"
          type="search"
          placeholder="Search birthday, white, kids..."
          aria-label="Search gallery styles"
          id="gallerySearch"
        />
      </div>
    </div>

    <div class="gallery-summary" aria-live="polite">
      <span id="galleryCount"><%= items.length %> designs shown</span>
      <a href="/orders" class="gallery-summary__link">Start a custom order</a>
    </div>

    <div class="gallerygrid" id="galleryGrid">
      <% if (items && items.length > 0) { %>
        <% items.forEach((it) => { %>
          <article
            class="gcard"
            data-cat="<%= it.category %>"
            data-title="<%= (it.title + ' ' + it.tag + ' ' + it.category).toLowerCase() %>"
          >
            <div class="gcard__media">
              <img src="<%= it.src %>" alt="<%= it.title %> cake" loading="lazy" />
              <span class="gcard__pill" data-category="<%= it.category %>"><%= it.tag %></span>
              <button class="gcard__preview" type="button" data-img="<%= it.src %>" data-title="<%= it.title %>">
                View
              </button>
            </div>

            <div class="gcard__body">
              <h3 class="gcard__title"><%= it.title %></h3>
              <p class="gcard__desc">Use this as inspiration. Bev can adjust colours, size, message, and flavour.</p>

              <div class="gcard__actions">
                <a class="btn btn--primary" href="/orders?style=<%= encodeURIComponent(it.title) %>&img=<%= encodeURIComponent(it.src) %>">
                  Choose this style
                </a>

                <button class="btn btn--ghost gcard__preview-action" type="button" data-img="<%= it.src %>" data-title="<%= it.title %>">
                  Quick view
                </button>
              </div>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <div class="empty">
          <div class="empty__title">No items available</div>
          <div class="empty__sub">Check back soon for new cake styles.</div>
        </div>
      <% } %>
    </div>

    <div class="empty" id="galleryEmpty" hidden>
      <div class="empty__title">No matches</div>
      <div class="empty__sub">Try another category or a different search word.</div>
    </div>
  </div>
</section>

<div class="modal" id="galleryModal" aria-hidden="true">
  <div class="modal__backdrop" data-close="true" role="button" tabindex="0" aria-label="Close preview"></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-label="Cake preview" tabindex="-1">
    <button class="modal__close" type="button" data-close="true" aria-label="Close preview">&times;</button>

    <div class="modal__media">
      <img id="modalImg" src="" alt="" />
    </div>

    <div class="modal__body">
      <div class="modal__title" id="modalTitle"></div>
      <div class="modal__actions">
        <a class="btn btn--primary" id="modalOrderBtn" href="#">Choose this style</a>
        <button class="btn btn--ghost" type="button" data-close="true">Close</button>
      </div>
      <p class="modal__fine">You can still customize everything in the order form. This only pre-fills the style.</p>
    </div>
  </div>
</div>

<script src="/js/gallery.js?v=gallery-catalogue-1" defer></script>
